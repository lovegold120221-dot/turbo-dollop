# Local Docker-only WhatsApp backend config.
# Copy to .env.whatsapp before running docker compose.

SANDBOX_PORT=4200
WHATSAPP_SERVER_PORT=4200
WA_AUTH_ROOT=/data/baileys
WA_LOG_LEVEL=silent
WA_SYNC_FULL_HISTORY=true
WA_HISTORY_LIMIT=50000
WA_HISTORY_RESPONSE_LIMIT=2000

# Optional: only needed for website-generation routes on this backend.
GEMINI_API_KEY=AIzaSyB8IwxUoV_lIdr0YC2hqVszeau7D75HHfk
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# After starting the container, expose it with:
# ngrok http 4200
# Then set the frontend backend URL to the ngrok HTTPS URL:
# VITE_BACKEND_URL=https://your-ngrok-domain.ngrok-free.app
